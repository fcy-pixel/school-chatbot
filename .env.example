# 複製此文件為 .env 並填入您的設定
# cp .env.example .env

# ── Qwen 國際版 API Key（必填）──────────────────────────────
# 在 https://dashscope-intl.aliyuncs.com/ 申請
QWEN_API_KEY=sk-your-qwen-api-key-here

# ── GitHub 倉庫設定（必填）──────────────────────────────────
# 格式：username/repository
GITHUB_REPO=your-username/your-school-repo

# PDF 文件所在的子目錄（選填，留空為根目錄）
GITHUB_PATH=pdfs

# GitHub Personal Access Token（選填，私有倉庫才需要）
GITHUB_TOKEN=
